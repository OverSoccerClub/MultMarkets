// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  OPERATOR
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum MarketStatus {
  DRAFT        // Created by bot, not yet reviewed
  PENDING      // Under admin review
  ACTIVE       // Live, accepting bets
  RESOLVED     // Outcome determined
  CANCELLED    // Cancelled (no payouts)
  CLOSED       // Betting closed, awaiting resolution
}

enum MarketOutcome {
  YES
  NO
  CANCELLED
}

enum TradeType {
  BUY
  SELL
}

enum TradeSide {
  YES
  NO
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  BET_DEBIT       // Funds locked when placing bet
  BET_REFUND      // Returned if market cancelled
  PAYOUT          // Winnings credited
  FEE             // Platform fee
  BONUS           // Promotional credits
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum BotSourceType {
  RSS
  NEWS_API
  REDDIT
  TWITTER
  GNEWS
}

enum TopicStatus {
  DISCOVERED
  SCORED
  DRAFT_GENERATED
  PENDING_REVIEW
  APPROVED
  REJECTED
  MARKET_CREATED
}

enum NotificationType {
  MARKET_RESOLVED
  POSITION_UPDATE
  DEPOSIT_CONFIRMED
  WITHDRAWAL_PROCESSED
  SYSTEM_ANNOUNCEMENT
  MARKET_ENDING_SOON
  NEW_MARKET
}

// ─── USERS ───────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  emailVerified     Boolean  @default(false)
  passwordHash      String
  name              String
  username          String   @unique
  avatarUrl         String?
  bio               String?
  role              Role     @default(USER)
  
  // 2FA
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?  // encrypted TOTP secret
  backupCodes       String[] // hashed backup codes
  
  // Account state
  isActive          Boolean  @default(true)
  isBanned          Boolean  @default(false)
  banReason         String?
  
  // Stats (denormalized for performance)
  totalVolume       Decimal  @default(0) @db.Decimal(18, 2)
  totalPnl          Decimal  @default(0) @db.Decimal(18, 2)
  marketsTraded     Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  lastLoginAt       DateTime?

  // Relations
  wallet            Wallet?
  sessions          UserSession[]
  emailTokens       EmailToken[]
  positions         Position[]
  trades            Trade[]
  notifications     Notification[]
  kyc               UserKyc?
  createdMarkets    Market[]  @relation("CreatedByUser")
  resolvedMarkets   Market[]  @relation("ResolvedByUser")
  reviewedDrafts    BotMarketDraft[] @relation("ReviewedByUser")

  @@map("users")
  @@index([email])
  @@index([username])
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  tokenHash   String   @unique
  deviceInfo  String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
  @@index([tokenHash])
}

model EmailToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  type      String   // "email_verify" | "password_reset"
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_tokens")
  @@index([token])
  @@index([userId])
}

model UserKyc {
  id           String    @id @default(cuid())
  userId       String    @unique
  status       KycStatus @default(NONE)
  documentType String?
  documentUrl  String?
  reviewedAt   DateTime?
  reviewNotes  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_kyc")
}

// ─── WALLET ──────────────────────────────────────────────────────────────────

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  balance       Decimal  @default(0)   @db.Decimal(18, 2) // available balance
  lockedBalance Decimal  @default(0)   @db.Decimal(18, 2) // funds in open positions
  currency      String   @default("BRL")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String            @id @default(cuid())
  walletId    String
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  balanceBefore Decimal         @db.Decimal(18, 2)
  balanceAfter  Decimal         @db.Decimal(18, 2)
  description String?
  referenceId String?           // tradeId, marketId, etc.
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  wallet      Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("wallet_transactions")
  @@index([walletId])
  @@index([type])
  @@index([createdAt])
}

// ─── CATEGORIES ──────────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  icon    String?
  color   String?  // hex color
  order   Int      @default(0)
  active  Boolean  @default(true)

  markets Market[]

  @@map("categories")
}

// ─── MARKETS ─────────────────────────────────────────────────────────────────

model Market {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  description      String        @db.Text
  resolutionCriteria String      @db.Text
  imageUrl         String?
  sourceUrl        String?       // original news article URL
  
  categoryId       String?
  status           MarketStatus  @default(DRAFT)
  outcome          MarketOutcome?
  
  // Pricing (AMM state)
  yesPrice         Decimal       @default(0.50) @db.Decimal(8, 6) // 0.00 - 1.00
  noPrice          Decimal       @default(0.50) @db.Decimal(8, 6)
  yesShares        Decimal       @default(1000) @db.Decimal(18, 6) // AMM liquidity
  noShares         Decimal       @default(1000) @db.Decimal(18, 6)
  liquidityPool    Decimal       @default(100)  @db.Decimal(18, 2) // initial liquidity in BRL
  
  // Stats
  totalVolume      Decimal       @default(0) @db.Decimal(18, 2)
  uniqueTraders    Int           @default(0)
  
  // Dates
  resolutionDate   DateTime?
  closedAt         DateTime?
  resolvedAt       DateTime?
  
  // Authorship
  createdByUserId  String?
  createdByBot     Boolean       @default(false)
  resolvedByUserId String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  // Relations
  category         Category?     @relation(fields: [categoryId], references: [id])
  createdByUser    User?         @relation("CreatedByUser", fields: [createdByUserId], references: [id])
  resolvedByUser   User?         @relation("ResolvedByUser", fields: [resolvedByUserId], references: [id])
  positions        Position[]
  trades           Trade[]
  priceHistory     MarketPricePoint[]
  botDraft         BotMarketDraft?

  @@map("markets")
  @@index([status])
  @@index([categoryId])
  @@index([resolutionDate])
  @@index([createdAt])
  @@index([totalVolume])
}

model MarketPricePoint {
  id        String   @id @default(cuid())
  marketId  String
  yesPrice  Decimal  @db.Decimal(8, 6)
  noPrice   Decimal  @db.Decimal(8, 6)
  volume    Decimal  @db.Decimal(18, 2)
  timestamp DateTime @default(now())

  market    Market   @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@map("market_price_points")
  @@index([marketId, timestamp])
}

// ─── TRADING ─────────────────────────────────────────────────────────────────

model Position {
  id             String    @id @default(cuid())
  userId         String
  marketId       String
  side           TradeSide
  shares         Decimal   @db.Decimal(18, 6)    // number of shares held
  avgPrice       Decimal   @db.Decimal(8, 6)     // weighted avg buy price
  totalCost      Decimal   @db.Decimal(18, 2)
  realizedPnl    Decimal   @default(0) @db.Decimal(18, 2)
  isSettled      Boolean   @default(false)
  settledAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User      @relation(fields: [userId], references: [id])
  market         Market    @relation(fields: [marketId], references: [id])

  @@unique([userId, marketId, side])
  @@map("positions")
  @@index([userId])
  @@index([marketId])
}

model Trade {
  id          String    @id @default(cuid())
  userId      String
  marketId    String
  type        TradeType
  side        TradeSide
  shares      Decimal   @db.Decimal(18, 6)
  price       Decimal   @db.Decimal(8, 6)  // price per share at time of trade
  totalCost   Decimal   @db.Decimal(18, 2) // shares * price
  fee         Decimal   @default(0) @db.Decimal(18, 2)
  
  // AMM state snapshot
  yesPriceAfter Decimal @db.Decimal(8, 6)
  noPriceAfter  Decimal @db.Decimal(8, 6)

  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id])
  market      Market    @relation(fields: [marketId], references: [id])

  @@map("trades")
  @@index([userId])
  @@index([marketId])
  @@index([createdAt])
}

// ─── BOT SYSTEM ──────────────────────────────────────────────────────────────

model BotSource {
  id            String        @id @default(cuid())
  name          String
  type          BotSourceType
  url           String
  active        Boolean       @default(true)
  fetchInterval Int           @default(30) // minutes
  lastFetchedAt DateTime?
  errorCount    Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  topics        BotTopic[]

  @@map("bot_sources")
}

model BotTopic {
  id             String      @id @default(cuid())
  sourceId       String?
  title          String
  summary        String?     @db.Text
  url            String?
  imageUrl       String?
  publishedAt    DateTime?
  language       String      @default("pt")
  
  // Scoring
  viralityScore  Float       @default(0) // 0-100
  sentimentScore Float       @default(0) // -1 to 1
  noveltyScore   Float       @default(0) // 0-1 (not seen before)
  finalScore     Float       @default(0) // weighted composite
  
  status         TopicStatus @default(DISCOVERED)
  processedAt    DateTime?
  createdAt      DateTime    @default(now())

  source         BotSource?  @relation(fields: [sourceId], references: [id])
  draft          BotMarketDraft?

  @@map("bot_topics")
  @@index([status])
  @@index([finalScore])
  @@index([createdAt])
}

model BotMarketDraft {
  id                  String       @id @default(cuid())
  topicId             String?      @unique
  marketId            String?      @unique // set when approved and market created
  
  // AI-generated content
  generatedTitle      String
  generatedDescription String      @db.Text
  resolutionCriteria  String      @db.Text
  suggestedCategory   String?
  suggestedEndDate    DateTime?
  aiModel             String?     // "gpt-4o", "gemini-1.5-pro" etc.
  aiPromptVersion     Int         @default(1)
  
  status              TopicStatus @default(DRAFT_GENERATED)
  reviewedByUserId    String?
  reviewedAt          DateTime?
  reviewNotes         String?
  
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  topic               BotTopic?   @relation(fields: [topicId], references: [id])
  market              Market?     @relation(fields: [marketId], references: [id])
  reviewedBy          User?       @relation("ReviewedByUser", fields: [reviewedByUserId], references: [id])

  @@map("bot_market_drafts")
  @@index([status])
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId, read])
  @@index([createdAt])
}

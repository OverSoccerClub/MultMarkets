# Dockerfile.web
FROM node:20-alpine AS base

# Step 1: Install alpine tools needed for turbo & gyp
RUN apk update && apk add --no-cache libc6-compat python3 make g++

FROM base AS builder
WORKDIR /app
RUN npm install -g turbo
COPY . .
# Prunes the workspace to only what's needed for 'web'
RUN turbo prune --scope=web --docker

FROM base AS installer
WORKDIR /app

# First install dependencies
COPY .gitignore .gitignore
COPY --from=builder /app/out/json/ .
COPY --from=builder /app/out/package-lock.json ./package-lock.json
RUN npm ci

# Copy source code of the pruned workspace
COPY --from=builder /app/out/full/ .

# Generate Prisma Client (required because the web app might depend on db)
RUN npx prisma generate --schema=packages/database/prisma/schema.prisma || true

# Build the project
RUN npm run build --filter=web...

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs
USER nextjs

COPY --from=installer /app/apps/web/next.config.js .
COPY --from=installer /app/apps/web/package.json .

# Copy the standalone output folder
COPY --from=installer --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
COPY --from=installer --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=installer --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# Start the standalone server
CMD ["node", "apps/web/server.js"]

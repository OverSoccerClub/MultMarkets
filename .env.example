# ────────────────────────────────────────────────────────────────────
# MultMarkets — Environment Variables Template
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────────────────────
# cp .env.example .env

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=multmarkets
POSTGRES_PASSWORD=multmarkets_dev_password
POSTGRES_DB=multmarkets
DATABASE_URL=postgresql://multmarkets:multmarkets_dev_password@localhost:5432/multmarkets

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-jwt-refresh-key-change-in-production

# ── Email (Nodemailer) ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MultMarkets <noreply@multmarkets.com>"

# ── File Storage ──────────────────────────────────────────────────────
# AWS S3 or Cloudflare R2
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ── Bot / AI ──────────────────────────────────────────────────────────
# OpenAI (for AI market generation)
OPENAI_API_KEY=sk-...your-key-here...

# NewsAPI (free tier: 100 req/day)
NEWS_API_KEY=your-newsapi-key

# GNews (optional alternative)
# GNEWS_API_KEY=

# ── Frontend (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=http://localhost:3001
